APP_NAME=docs-graph-rag
APP_ENV=local
APP_ALLOW_REMOTE_PROVIDERS=false

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=deepseek-r1:8b
OLLAMA_EXTRACT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=neo4j

TEMPORAL_REFRESH_MINUTES=360
TEMPORAL_HTTP_TIMEOUT_SECONDS=20
GRAPHRAG_V2_INDEX_NAME=chunk-vector-index
GRAPHRAG_V2_TOP_K=5
GRAPHRAG_V2_EMBEDDING_DIMS=768
